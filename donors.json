<script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>

<script>
  // Replace your old fetch('donors.json') code with this:
  fetch('donors.csv')
    .then(response => response.text())
    .then(csvData => {
      // This automatically turns your CSV file into a perfect JSON array!
      let donors = Papa.parse(csvData, { header: true, skipEmptyLines: true }).data;
      
      // Now use the 'donors' variable exactly how you did before
      console.log(donors); 
    });
</script>
